# CRM System - Environment Variables
# Copy to .env and fill in values before running

# Security
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Backend
APP_NAME=CRM API
APP_VERSION=1.0.0
DEBUG=false

# Database (SQLite for dev, switch to PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./data/crm.db

# CORS (comma-separated origins)
ALLOWED_ORIGINS=*
